{
  "description": "Ctrl/Cmd+Space Swap",
  "manipulators": [
    {
      "from": {
        "key_code": "spacebar",
        "modifiers": { "mandatory": ["command"] }
      },
      "to": [
        {
          "key_code": "spacebar",
          "modifiers": "left_control"
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "spacebar",
        "modifiers": { "mandatory": ["control"] }
      },
      "to": [
        {
          "key_code": "spacebar",
          "modifiers": "left_command"
        }
      ],
      "type": "basic"
    }
  ]
}
