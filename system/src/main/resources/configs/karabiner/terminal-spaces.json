{
  "description": "Spaces for Terminal",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.apple\\.Terminal",
            "^com\\.mitchellh\\.ghostty"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "left_arrow",
        "modifiers": { "mandatory": ["command"] }
      },
      "to": {
        "key_code": "left_arrow",
        "modifiers": ["control"]
      },
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.apple\\.Terminal",
            "^com\\.mitchellh\\.ghostty"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "right_arrow",
        "modifiers": { "mandatory": ["command"] }
      },
      "to": {
        "key_code": "right_arrow",
        "modifiers": ["control"]
      },
      "type": "basic"
    }
  ]
}
